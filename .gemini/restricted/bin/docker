#!/bin/bash
# docker-wrapper.sh
#
# INTERCEPTOR FOR GEMINI CLI SANDBOX MOUNTS
#
# Background: The default Gemini CLI hardcodes a volume mount for `~/.config/gcloud`
# into the sandbox container. This causes personal host credentials to "leak" into
# the sandbox environment.
#
# Because Docker prevents you from masking a directory mount with an empty directory
# (duplicate mount point error), and the GCP SDKs (google-auth-library) are very
# brittle and crash if they find an empty file masking the credentials, we must
# completely prevent the directory from being mounted in the first place.
#
# This script is temporarily prepended to the $PATH before executing the Gemini CLI.
# When the CLI invokes `docker run ...`, this wrapper intercepts the call, scans the
# arguments, silently strips out the `--volume ~/.config/gcloud` flags, and forwards
# the rest to the real Docker binary.
#
# This forces the GCP SDKs inside the sandbox to fall back to the Metadata server
# since the credential files are physically absent.

NEW_ARGS=()
SKIP_NEXT=false
for ((i = 1; i <= $#; i++)); do
  if [[ ${SKIP_NEXT} == true ]]; then
    SKIP_NEXT=false
    continue
  fi

  ARG="${!i}"

  # Check if this is a volume flag with the path embedded in it
  if [[ ${ARG} == "-v" || ${ARG} == "--volume" ]]; then
    NEXT_INDEX=$((i + 1))
    NEXT_ARG="${!NEXT_INDEX}"
    # ONLY strip the gcloud config directory mount. Do NOT strip .gemini directory.
    if [[ ${NEXT_ARG} == *":${HOME}/.config/gcloud:ro"* ]] || [[ ${NEXT_ARG} == *":${HOME}/.config/gcloud"* ]]; then
      # echo "[DOCKER-WRAPPER] Stripping gcloud mount: $ARG $NEXT_ARG" >&2
      SKIP_NEXT=true
      continue
    fi
  elif [[ ${ARG} == *"-v"* && ${ARG} == *":${HOME}/.config/gcloud"* ]]; then
    # echo "[DOCKER-WRAPPER] Stripping embedded gcloud mount: $ARG" >&2
    continue
  fi

  NEW_ARGS+=("${ARG}")
done

# Run the real docker
exec /usr/bin/docker "${NEW_ARGS[@]}"
